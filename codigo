#include "Adafruit_LEDBackpack.h"

int b1 = 0;

int b2 = 0;

int b3 = 0;

int sol = 0;

Adafruit_7segment led_display1 = Adafruit_7segment();

void setup()
{
  pinMode(A1, INPUT);
  Serial.begin(9600);
  pinMode(2, INPUT);
  led_display1.begin(112);
  pinMode(5, OUTPUT);
  pinMode(6, OUTPUT);
  pinMode(9, OUTPUT);
  pinMode(4, INPUT);
  pinMode(8, INPUT);
}

void loop()
{
  sol = map(analogRead(A1), 0, 1023, 0, 300);
  Serial.println(sol);
  if (digitalRead(2) == 1) {
    b1 = digitalRead(2);
    led_display1.println("300");
    led_display1.writeDisplay();
    analogWrite(5, 255);
    analogWrite(6, 0);
    analogWrite(9, 0);
    if (digitalRead(4) == 1) {
      b2 = digitalRead(4);
      analogWrite(5, 0);
      analogWrite(6, 255);
      analogWrite(9, 0);
      if (digitalRead(8) == 1) {
        b3 = digitalRead(8);
        analogWrite(5, 0);
        analogWrite(6, 0);
        analogWrite(9, 255);
      }
    }
  }
  delay(10); // Delay a little bit to improve simulation performance
}
